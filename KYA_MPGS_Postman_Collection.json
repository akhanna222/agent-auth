{
  "info": {
    "name": "KYA × Mastercard MPGS — Sandbox Collection",
    "description": "Complete Postman collection for testing KYA (Know Your Agent) integration with Mastercard MPGS. All requests pre-configured for the sandbox environment. Run the 'Quickstart' folder first to verify connectivity.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",  "value": "https://sandbox.kya.moofwd.io/v1", "type": "string" },
    { "key": "api_key",   "value": "kya_sandbox_mc_test_4f8a2b1c9d",   "type": "string" },
    { "key": "tenant_id", "value": "mastercard-sandbox",                "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{api_key}}", "type": "string" }]
  },
  "item": [

    {
      "name": "00 — Quickstart (run first)",
      "description": "Verify sandbox is reachable and credentials work. Run all three in order.",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/../health/ready",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ]
          },
          "response": [],
          "_postman_previewlanguage": "json",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health check passes', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.equal('healthy');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify sandbox agent exists",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/agents/agt_mc_test_001",
            "header": [
              { "key": "X-Tenant-ID",    "value": "{{tenant_id}}" },
              { "key": "Authorization",  "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",   "value": "req_quickstart_001" }
            ]
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Agent exists and is active', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.status).to.equal('active');",
                  "  pm.expect(d.trust_tier).to.equal('verified');",
                  "  console.log('Agent:', d.display_name, '| Trust:', d.trust_tier);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "First verification call — expect ALLOW",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/verify-agent-action",
            "header": [
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "X-Tenant-ID",    "value": "{{tenant_id}}" },
              { "key": "Authorization",  "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",   "value": "req_quickstart_002" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"agt_mc_test_001\",\n  \"signed_token\": \"tok_mc_allow_sandbox\",\n  \"action\": \"payment.create\",\n  \"action_payload\": {\n    \"amount_usd\": 1200,\n    \"currency\": \"USD\",\n    \"merchant_id\": \"MCH_TEST_001\",\n    \"invoice_ref\": \"INV-SANDBOX-001\"\n  },\n  \"request_context\": {\n    \"ip_address\": \"203.0.113.1\",\n    \"user_agent\": \"MPGS-Gateway/4.1\",\n    \"timestamp\": \"{{$isoTimestamp}}\"\n  }\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Decision is ALLOW', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.decision).to.equal('allow');",
                  "  pm.expect(d.is_agent_valid).to.be.true;",
                  "  pm.expect(d.is_authorized).to.be.true;",
                  "  pm.expect(d.risk_score).to.be.below(30);",
                  "  console.log('Decision:', d.decision, '| Risk:', d.risk_score, '| Latency:', pm.response.responseTime + 'ms');",
                  "  pm.collectionVariables.set('last_decision_id', d.decision_id);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "01 — Verify agent action (all scenarios)",
      "description": "Complete test matrix for POST /v1/verify-agent-action. Each request tests one specific scenario. Run in sequence.",
      "item": [
        {
          "name": "ALLOW — normal payment $1,200",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/verify-agent-action",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_allow_001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"agt_mc_test_001\",\n  \"signed_token\": \"tok_mc_allow_sandbox\",\n  \"action\": \"payment.create\",\n  \"action_payload\": {\n    \"amount_usd\": 1200,\n    \"currency\": \"USD\",\n    \"merchant_id\": \"MCH_TEST_001\",\n    \"invoice_ref\": \"INV-SANDBOX-001\"\n  },\n  \"request_context\": {\n    \"ip_address\": \"203.0.113.1\",\n    \"user_agent\": \"MPGS-Gateway/4.1\",\n    \"timestamp\": \"{{$isoTimestamp}}\"\n  }\n}"
            }
          },
          "response": [
            {
              "name": "200 — allow",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"is_agent_valid\": true,\n    \"is_authorized\": true,\n    \"risk_score\": 7,\n    \"decision\": \"allow\",\n    \"decision_id\": \"dec_sandbox_abc123\",\n    \"constraints_verified\": {\n      \"amount_within_limit\": true,\n      \"delegation_active\": true,\n      \"token_valid\": true,\n      \"time_window_valid\": true\n    },\n    \"processed_at\": \"2025-01-07T14:00:00.067Z\"\n  },\n  \"meta\": {\n    \"request_id\": \"req_allow_001\",\n    \"latency_ms\": 67,\n    \"version\": \"1.0\"\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('ALLOW — status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ALLOW — decision correct', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.decision).to.equal('allow');",
                  "  pm.expect(d.risk_score).to.be.below(30);",
                  "  pm.expect(d.is_authorized).to.be.true;",
                  "});",
                  "pm.test('ALLOW — latency under 100ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(100);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "STEP-UP — amount $7,500 exceeds threshold",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/verify-agent-action",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_stepup_001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"agt_mc_test_001\",\n  \"signed_token\": \"tok_mc_stepup_sandbox\",\n  \"action\": \"payment.create\",\n  \"action_payload\": {\n    \"amount_usd\": 7500,\n    \"currency\": \"USD\",\n    \"merchant_id\": \"MCH_TEST_002\",\n    \"invoice_ref\": \"INV-SANDBOX-LARGE-001\"\n  },\n  \"request_context\": {\n    \"ip_address\": \"203.0.113.1\",\n    \"user_agent\": \"MPGS-Gateway/4.1\",\n    \"timestamp\": \"{{$isoTimestamp}}\"\n  }\n}"
            }
          },
          "response": [
            {
              "name": "200 — step_up",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"is_agent_valid\": true,\n    \"is_authorized\": false,\n    \"risk_score\": 18,\n    \"decision\": \"step_up\",\n    \"decision_id\": \"dec_sandbox_stepup_001\",\n    \"challenge_id\": \"chal_sandbox_xyz\",\n    \"challenge_type\": \"push_notification\",\n    \"poll_url\": \"https://sandbox.kya.moofwd.io/v1/stepup/chal_sandbox_xyz/status\",\n    \"expires_at\": \"2025-01-07T14:05:00Z\"\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('STEP-UP — decision correct', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.decision).to.equal('step_up');",
                  "  pm.expect(d.challenge_id).to.be.a('string');",
                  "  pm.expect(d.poll_url).to.include('/stepup/');",
                  "  pm.collectionVariables.set('challenge_id', d.challenge_id);",
                  "  pm.collectionVariables.set('poll_url', d.poll_url);",
                  "  console.log('Challenge ID:', d.challenge_id);",
                  "  console.log('Poll URL:', d.poll_url);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "DENY — revoked agent",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/verify-agent-action",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_deny_revoked_001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"agt_mc_test_revoked\",\n  \"signed_token\": \"tok_mc_any_sandbox\",\n  \"action\": \"payment.create\",\n  \"action_payload\": {\n    \"amount_usd\": 500,\n    \"currency\": \"USD\",\n    \"merchant_id\": \"MCH_TEST_001\"\n  },\n  \"request_context\": {\n    \"ip_address\": \"203.0.113.99\",\n    \"user_agent\": \"MPGS-Gateway/4.1\",\n    \"timestamp\": \"{{$isoTimestamp}}\"\n  }\n}"
            }
          },
          "response": [
            {
              "name": "200 — deny AGENT_REVOKED",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"is_agent_valid\": false,\n    \"is_authorized\": false,\n    \"risk_score\": 100,\n    \"decision\": \"deny\",\n    \"decision_id\": \"dec_sandbox_deny_001\",\n    \"denial_reason\": \"AGENT_REVOKED\"\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('DENY — AGENT_REVOKED', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.decision).to.equal('deny');",
                  "  pm.expect(d.denial_reason).to.equal('AGENT_REVOKED');",
                  "  pm.expect(d.risk_score).to.equal(100);",
                  "  pm.expect(d.is_agent_valid).to.be.false;",
                  "});",
                  "pm.test('DENY — fast response (Redis only)', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(25);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "DENY — amount exceeds delegation limit",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/verify-agent-action",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_deny_limit_001" }
            ],
            "body": {
              "mode": "raw",

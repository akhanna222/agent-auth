                  "pm.test('Step-up rejected — token revoked', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.status).to.equal('rejected');",
                  "  pm.expect(d.upgraded_token).to.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "03 — Revocation (kill switch)",
      "description": "Test the instant revocation flow. Warning: revocation in sandbox is real but sandbox agents auto-reset every 24 hours.",
      "item": [
        {
          "name": "Verify before revocation — expect ALLOW",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/verify-agent-action",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_pre_revoke_001" }
            ],
            "body": {
              "mode": "raw",

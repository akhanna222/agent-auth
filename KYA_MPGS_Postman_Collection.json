            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('DENY — AMOUNT_EXCEEDS_LIMIT', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.decision).to.equal('deny');",
                  "  pm.expect(d.denial_reason).to.equal('AMOUNT_EXCEEDS_LIMIT');",

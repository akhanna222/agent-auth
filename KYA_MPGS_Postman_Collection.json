              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_deny_replay_001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"agt_mc_test_001\",\n  \"signed_token\": \"tok_mc_used_sandbox\",\n  \"action\": \"payment.create\",\n  \"action_payload\": {\n    \"amount_usd\": 500,\n    \"currency\": \"USD\",\n    \"merchant_id\": \"MCH_TEST_001\"\n  },\n  \"request_context\": {\n    \"ip_address\": \"203.0.113.1\",\n    \"user_agent\": \"MPGS-Gateway/4.1\",\n    \"timestamp\": \"{{$isoTimestamp}}\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('DENY — TOKEN_ALREADY_USED (replay blocked)', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.decision).to.equal('deny');",
                  "  pm.expect(d.denial_reason).to.equal('TOKEN_ALREADY_USED');",
                  "});"
                ]
              }
            }
          ]
        },


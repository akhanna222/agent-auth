    {
      "name": "02 — Step-up challenge flow",
      "description": "After receiving step_up from verify-agent-action, use these to poll and resolve the challenge. Run after the STEP-UP scenario in folder 01.",
      "item": [
        {
          "name": "Poll step-up status (pending)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/stepup/{{challenge_id}}/status",
            "header": [
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_poll_001" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Poll returns valid status', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(['pending','approved','rejected','expired']).to.include(d.status);",
                  "  console.log('Challenge status:', d.status);",
                  "  if(d.status === 'approved') {",
                  "    pm.collectionVariables.set('upgraded_token', d.upgraded_token);",
                  "    console.log('Upgraded token received — proceed with payment');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Resolve step-up — APPROVE (sandbox simulation)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/stepup/{{challenge_id}}/respond",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_stepup_approve_001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"approve\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Step-up approved', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.status).to.equal('approved');",
                  "  pm.expect(d.upgraded_token).to.be.a('string');",
                  "  pm.collectionVariables.set('upgraded_token', d.upgraded_token);",
                  "  console.log('Upgraded token:', d.upgraded_token.substring(0,20) + '...');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Verify with upgraded token — expect ALLOW",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/verify-agent-action",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "X-Request-ID",  "value": "req_stepup_verify_001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"agt_mc_test_001\",\n  \"signed_token\": \"{{upgraded_token}}\",\n  \"action\": \"payment.create\",\n  \"action_payload\": {\n    \"amount_usd\": 7500,\n    \"currency\": \"USD\",\n    \"merchant_id\": \"MCH_TEST_002\",\n    \"invoice_ref\": \"INV-SANDBOX-LARGE-001\"\n  },\n  \"request_context\": {\n    \"ip_address\": \"203.0.113.1\",\n    \"user_agent\": \"MPGS-Gateway/4.1\",\n    \"timestamp\": \"{{$isoTimestamp}}\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Upgraded token gives ALLOW', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.decision).to.equal('allow');",
                  "  console.log('Full step-up flow complete — €7,500 payment authorised');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Resolve step-up — REJECT",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/stepup/chal_sandbox_reject_test/respond",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Tenant-ID",   "value": "{{tenant_id}}" },
